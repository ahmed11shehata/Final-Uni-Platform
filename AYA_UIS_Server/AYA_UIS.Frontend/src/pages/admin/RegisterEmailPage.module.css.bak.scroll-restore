.rolePopupOverlay {
  position:fixed;
  inset:0;
  z-index:9997;
  background:rgba(5,10,22,.24);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  display:flex;
  align-items:center;
  justify-content:center;
  padding:24px;
}
.rolePopup {
  width:min(1120px, calc(100vw - 48px));
  max-height:min(82vh, 820px);
  overflow:hidden;
  border-radius:24px;
  border:1.5px solid color-mix(in srgb, var(--accent,#818cf8) 16%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--accent,#818cf8) 4%, transparent), transparent 38%),
    var(--card-bg);
  box-shadow:0 28px 80px rgba(2,6,23,.28);
  display:flex;
  flex-direction:column;
}
.rolePopupHeader {
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16px;
  padding:20px 22px 14px;
  border-bottom:1px solid var(--border);
}
.rolePopupTitle {
  margin:0 0 4px;
  font-size:1.08rem;
  font-weight:900;
  color:var(--text-primary);
}
.rolePopupSub {
  margin:0;
  font-size:.8rem;
  color:var(--text-muted);
}
.rolePopupHeadActions {
  display:flex;
  align-items:center;
  gap:10px;
}
.rolePopupSearch {
  min-width:320px;
  display:flex;
  align-items:center;
  gap:8px;
  padding:10px 12px;
  border-radius:14px;
  border:1.5px solid var(--border);
  background:var(--hover-bg);
}
.rolePopupSearch:focus-within { border-color:#818cf8; box-shadow:0 0 0 4px rgba(129,140,248,.08); }
.rolePopupSearchIcon { width:15px; height:15px; display:flex; color:var(--text-muted); flex-shrink:0; }
.rolePopupSearchIcon svg { width:15px; height:15px; }
.rolePopupSearchInp {
  flex:1;
  border:none;
  outline:none;
  background:none;
  min-width:0;
  color:var(--text-primary);
  font-family:'Sora',sans-serif;
  font-size:.84rem;
}
.rolePopupSearchInp::placeholder { color:var(--text-muted); }
.rolePopupSearchClear,
.rolePopupClose {
  width:38px; height:38px;
  border-radius:12px;
  border:1.5px solid var(--border);
